{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/AppAgentCards/spec/v0.1/schema.json",
  "title": "AppAgentCards Manifest",
  "description": "Normative JSON Schema for the AppAgentCards SPEC v0.1. Cards are authored in YAML; this schema describes the equivalent JSON structure after parse.",

  "type": "object",
  "additionalProperties": false,
  "required": [
    "spec_version",
    "card_version",
    "app_id",
    "app_name",
    "platforms",
    "locale",
    "embedded_agent",
    "provenance",
    "constraints"
  ],
  "properties": {
    "spec_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+(?:\\.\\d+)?$",
      "description": "Semver of the SPEC this card targets."
    },
    "card_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semver of this card file. See SPEC §11."
    },
    "app_id": {
      "type": "string",
      "minLength": 1,
      "description": "Android package name or iOS bundle id."
    },
    "app_name": {
      "type": "string",
      "minLength": 1
    },
    "platforms": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "enum": ["android", "ios", "harmonyos"] }
    },
    "locale": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-zA-Z]{2,3}(?:-[A-Za-z0-9]{2,8})*$",
        "description": "BCP-47 language tag."
      }
    },
    "embedded_agent": { "$ref": "#/definitions/embedded_agent" },
    "provenance":     { "$ref": "#/definitions/provenance" },
    "constraints":    { "$ref": "#/definitions/constraints" }
  },

  "definitions": {

    "selector": {
      "description": "Reaches a single UI node. v0.1 selectors are single-field except for the x_-prefixed last-resort fields. See SPEC §6.1 and SPEC-OPEN-QUESTIONS OQ-10/11.",
      "type": "object",
      "minProperties": 1,
      "properties": {
        "accessibility_id": { "type": "string" },
        "resource_id":      { "type": "string" },
        "text":             { "type": "string" },
        "text_contains":    { "type": "string" },
        "xpath":            { "type": "string" },
        "x_bounds":         { "$ref": "#/definitions/x_bounds" }
      },
      "patternProperties": {
        "^x_": {}
      },
      "additionalProperties": false
    },

    "x_bounds": {
      "description": "Last-resort selector by absolute pixel rectangle on the verified device. Requires provenance.x_device_metrics. See SPEC §6.1.",
      "type": "object",
      "required": ["box"],
      "properties": {
        "box": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "items": { "type": "integer", "minimum": 0 },
          "description": "[x1, y1, x2, y2] in pixels on the verified device."
        },
        "anchor": {
          "enum": ["top_left", "top_right", "bottom_left", "bottom_right", "center", "none"],
          "description": "Author claim about layout pinning; routers use this to pick a remapping strategy."
        }
      },
      "additionalProperties": false
    },

    "step": {
      "description": "One step of a tap_sequence. Exactly one of `tap`, `tap_label`, `tap_screen_fraction`, `swipe`, or `wait`.",
      "type": "object",
      "oneOf": [
        {
          "required": ["tap"],
          "properties": { "tap": { "$ref": "#/definitions/selector" } },
          "additionalProperties": false
        },
        {
          "required": ["tap_label"],
          "properties": {
            "tap_label": {
              "type": "object",
              "oneOf": [
                { "required": ["text"],                  "properties": { "text": { "type": "string" } }, "additionalProperties": false },
                { "required": ["text_contains"],          "properties": { "text_contains": { "type": "string" } }, "additionalProperties": false },
                { "required": ["text_or_desc"],            "properties": { "text_or_desc": { "type": "string" } }, "additionalProperties": false },
                { "required": ["text_or_desc_contains"],   "properties": { "text_or_desc_contains": { "type": "string" } }, "additionalProperties": false },
                { "required": ["accessibility_id"],        "properties": { "accessibility_id": { "type": "string" } }, "additionalProperties": false }
              ],
              "properties": {
                "timeout_seconds": { "type": "number", "minimum": 0 },
                "scroll_attempts": { "type": "integer", "minimum": 0 },
                "required":        { "type": "boolean" }
              },
              "patternProperties": { "^x_": {} },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        {
          "required": ["tap_screen_fraction"],
          "properties": {
            "tap_screen_fraction": {
              "type": "object",
              "required": ["x_ratio", "y_ratio"],
              "properties": {
                "x_ratio": { "type": "number" },
                "y_ratio": { "type": "number" },
                "label":   { "type": "string" }
              },
              "patternProperties": { "^x_": {} },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        {
          "required": ["swipe"],
          "properties": {
            "swipe": {
              "type": "object",
              "required": ["from", "to"],
              "properties": {
                "from":        { "type": "string", "description": "[x,y]" },
                "to":          { "type": "string", "description": "[x,y]" },
                "duration_ms": { "type": "integer", "minimum": 0 }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        {
          "required": ["wait"],
          "properties": {
            "wait": {
              "type": "object",
              "oneOf": [
                { "required": ["ms"],    "properties": { "ms":    { "type": "integer", "minimum": 0 } }, "additionalProperties": false },
                { "required": ["until"], "properties": { "until": { "$ref": "#/definitions/selector" } }, "additionalProperties": false }
              ]
            }
          },
          "additionalProperties": false
        }
      ]
    },

    "precondition": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string", "description": "Free-form precondition tag (login_required, permission, first_run_dialog, etc.)." },
        "permission": { "type": "string" },
        "dismiss":    { "$ref": "#/definitions/step" }
      },
      "patternProperties": { "^x_": {} },
      "additionalProperties": false
    },

    "entry": {
      "type": "object",
      "required": ["primary"],
      "properties": {
        "primary":       { "$ref": "#/definitions/entry_method" },
        "fallback":      { "type": "array", "items": { "$ref": "#/definitions/entry_method" } },
        "preconditions": { "type": "array", "items": { "$ref": "#/definitions/precondition" } }
      },
      "patternProperties": { "^x_": {} },
      "additionalProperties": false
    },

    "entry_method": {
      "oneOf": [
        {
          "type": "object",
          "required": ["method", "uri"],
          "properties": {
            "method": { "const": "deep_link" },
            "uri": { "type": "string", "format": "uri" }
          },
          "patternProperties": { "^x_": {} },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["method", "action"],
          "properties": {
            "method": { "const": "intent" },
            "action":    { "type": "string" },
            "component": { "type": "string" },
            "extras":    { "type": "object" }
          },
          "patternProperties": { "^x_": {} },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["method", "steps"],
          "properties": {
            "method": { "const": "tap_sequence" },
            "steps": { "type": "array", "minItems": 0, "items": { "$ref": "#/definitions/step" } }
          },
          "patternProperties": { "^x_": {} },
          "additionalProperties": false
        }
      ]
    },

    "invocation": {
      "type": "object",
      "required": ["input", "submit"],
      "properties": {
        "input": {
          "type": "object",
          "required": ["field"],
          "properties": {
            "field":     { "$ref": "#/definitions/selector" },
            "max_chars": { "type": "integer", "minimum": 1 }
          },
          "patternProperties": { "^x_": {} },
          "additionalProperties": false
        },
        "submit": {
          "type": "object",
          "required": ["trigger"],
          "properties": {
            "trigger": { "$ref": "#/definitions/selector" }
          },
          "patternProperties": { "^x_": {} },
          "additionalProperties": false
        },
        "prompt_template": { "type": "string" }
      },
      "patternProperties": { "^x_": {} },
      "additionalProperties": false
    },

    "output": {
      "type": "object",
      "required": ["method"],
      "properties": {
        "method": { "enum": ["none", "screen_text_extract", "accessibility_tree"] },
        "completion_signal": {
          "type": "object",
          "required": ["type"],
          "properties": {
            "type":       { "enum": ["text_match"] },
            "patterns":   { "type": "array", "items": { "type": "string" }, "minItems": 1 },
            "timeout_ms": { "type": "integer", "minimum": 0 }
          },
          "patternProperties": { "^x_": {} },
          "additionalProperties": false
        }
      },
      "patternProperties": { "^x_": {} },
      "additionalProperties": false
    },

    "side_effect": {
      "enum": [
        "payment",
        "external_communication",
        "data_write",
        "data_delete",
        "physical_action",
        "none"
      ]
    },

    "capability": {
      "type": "object",
      "required": [
        "id",
        "description",
        "example_prompts",
        "executable",
        "side_effects",
        "requires_login",
        "reversible",
        "handoff_to_user_required"
      ],
      "properties": {
        "id":              { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "description":     { "type": "string", "minLength": 1 },
        "example_prompts": {
          "type": "array",
          "minItems": 2,
          "items": { "type": "string", "minLength": 1 }
        },
        "executable":               { "type": "boolean" },
        "side_effects": {
          "type": "array",
          "items": { "$ref": "#/definitions/side_effect" },
          "uniqueItems": true
        },
        "requires_login":           { "type": "boolean" },
        "reversible":               { "type": "boolean" },
        "handoff_to_user_required": { "type": "boolean" },
        "typical_latency_seconds":  { "type": "number", "minimum": 0 },
        "failure_modes":            { "type": "array", "items": { "type": "string" } }
      },
      "patternProperties": { "^x_": {} },
      "additionalProperties": false,
      "allOf": [
        {
          "description": "If `none` appears in side_effects, it must be the only entry (SPEC §8.2).",
          "if":   { "properties": { "side_effects": { "type": "array", "contains": { "const": "none" } } } },
          "then": { "properties": { "side_effects": { "type": "array", "maxItems": 1 } } }
        }
      ]
    },

    "embedded_agent": {
      "type": "object",
      "required": ["name", "type", "description", "entry", "invocation", "capabilities"],
      "properties": {
        "name":         { "type": "string", "minLength": 1 },
        "type":         { "enum": ["native_in_app_agent", "chat_widget", "smart_search", "voice_assistant"] },
        "description":  { "type": "string", "minLength": 1 },
        "entry":        { "$ref": "#/definitions/entry" },
        "invocation":   { "$ref": "#/definitions/invocation" },
        "output":       { "$ref": "#/definitions/output" },
        "capabilities": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/capability" }
        }
      },
      "patternProperties": { "^x_": {} },
      "additionalProperties": false
    },

    "provenance": {
      "type": "object",
      "required": ["last_verified", "verified_app_version", "verified_os", "verification_method"],
      "properties": {
        "last_verified":        { "type": "string", "format": "date" },
        "verified_app_version": { "type": "string", "minLength": 1 },
        "verified_os":          { "type": "string", "pattern": "^(android|ios|harmonyos)-[0-9]+(?:\\.[0-9]+)*$" },
        "verified_device":      { "type": "string" },
        "verification_method":  { "enum": ["manual", "scripted", "community_reported"] },
        "evidence_url":         { "type": "string" },
        "x_device_metrics":     { "$ref": "#/definitions/x_device_metrics" }
      },
      "patternProperties": { "^x_": {} },
      "additionalProperties": false
    },

    "x_device_metrics": {
      "description": "Screen metrics of the verified device. Required (validators warn) when any x_bounds selector appears in the card.",
      "type": "object",
      "required": ["resolution_px", "density_dpi"],
      "properties": {
        "resolution_px": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": { "type": "integer", "minimum": 1 }
        },
        "density_dpi": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },

    "constraints": {
      "type": "object",
      "required": ["app_version_min", "network_required"],
      "properties": {
        "app_version_min": { "type": "string", "minLength": 1 },
        "app_version_max": { "type": "string" },
        "region": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[A-Z]{2}$" },
          "uniqueItems": true
        },
        "network_required": { "type": "boolean" },
        "known_issues":     { "type": "array", "items": { "type": "string" } }
      },
      "patternProperties": { "^x_": {} },
      "additionalProperties": false
    }
  }
}
