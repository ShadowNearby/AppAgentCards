# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.

# Path to adb executable (optional; auto-detected from PATH if not set)
# ADB=/path/to/adb

# Vision API (optional; for opt-in vision summaries in tests)
# VISION_BASE_URL=https://your-vision-api.example.com/v1
# VISION_API_KEY=sk-your-key-here
# VISION_MODEL=qwen
