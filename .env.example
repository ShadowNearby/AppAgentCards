# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.

# ── LLM endpoint (REQUIRED for scripts/run_test.py and scripts/run_flow.py) ──
# OpenAI-compatible chat-completions endpoint. Any provider works — Anthropic
# via a proxy, OpenAI, vLLM, Qwen, etc.
LLM_BASE_URL=https://your-llm-gateway.example.com/v1
LLM_API_KEY=sk-your-key-here
LLM_MODEL=qwen

# ── Optional adapter knobs (read by agents/appcards_agent.py) ──
# Override which manifests directory to load cards from.
# APPCARDS_MANIFESTS=/abs/path/to/manifests
# Your device's density in DPI; enables dp-aware x_bounds remapping.
# APPCARDS_TARGET_DENSITY=480
# Set to "0" to keep the previous conversation context across runs.
# APPCARDS_FRESH_CONV=1
# Multi-device setups: pin every adb call to one serial.
# APPCARDS_ANDROID_SERIAL=ABCDEF1234
# wait_for_reply capture_full: vertical swipe distance as fraction of screen
# height (clamped to 0.1–0.95). Higher = fewer VLM polls but more risk of
# missing text at the seam. Default 0.7.
# APPCARDS_CAPTURE_SCROLL_RATIO=0.7

# ── Path to adb executable (optional; auto-detected from PATH if not set) ──
# ADB=/path/to/adb
